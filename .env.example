# Copy this file to .env and adjust values as needed.

APP_URL=http://localhost:3000  # Application URL for OIDC callback and redirects
JWT_SECRET=supersecretkey # auto-generated and persisted in /data if not set

# Postgres — Docker Compose sets PG_HOST=host.docker.internal in docker-compose.yml
# so Anchor uses Postgres on the SAME VM (not embedded). Override credentials here;
# Compose reads this file for ${PG_USER}, ${PG_PASSWORD}, etc. substitution.
#
# On the host, ensure Postgres listens for Docker (e.g. listen_addresses and pg_hba.conf
# allowing your bridge subnet, often 172.17.0.0/16).
#
# To use embedded Postgres instead: remove PG_HOST from docker-compose.yml environment
# (or set PG_HOST="" there) and do not pass PG_HOST.
PG_HOST=host.docker.internal
PG_USER=anchor
PG_PASSWORD=password
PG_DATABASE=anchor
PG_PORT=5432

# Optional: Set to 'disabled', 'enabled', or 'review' to lock sign up mode.
# If not set, admins can control it via the admin panel.
# USER_SIGNUP=enabled

### OIDC Authentication (optional)
# OIDC_ENABLED=false
# OIDC_PROVIDER_NAME="Pocket ID"
# OIDC_ISSUER_URL=https://auth.example.com
# OIDC_CLIENT_ID=your-client-id
# OIDC_CLIENT_SECRET=your-client-secret  # Optional: omit for public client (PKCE)
# DISABLE_INTERNAL_AUTH=false  # Hide local login form when OIDC is enabled

### Email (password reset OTP via Resend)
# RESEND_API_KEY=re_xxxx
# RESEND_FROM="Anchor <notifications@yourdomain.com>"
# Without RESEND_API_KEY, reset codes are logged on the server only (development).

### HTTPS on your LAN (recommended for registration / encrypted notes)
# The browser only exposes Web Crypto (encryption at signup and for notes) on a
# [secure context](https://developer.mozilla.org/en-US/docs/Web/Security/Secure_Contexts).
# Plain http:// to a LAN IP (e.g. http://192.168.1.50:3000) is NOT secure — crypto stays disabled.
# On a private network, serve Anchor over HTTPS anyway: reverse proxy (Caddy/nginx/Traefik) with
# a certificate from mkcert, smallstep, or your own CA; trust the CA on devices that use the app.
# Alternatively access via http://localhost on the machine running the browser only.